--- /dev/null
+++ b/server/src/modules/history/notes.repo.ts
@@ -0,0 +1,20 @@
+import { and, eq } from 'drizzle-orm';
+import type { Db } from '../../db/client.js';
+import * as t from '../../db/schema.js';
+
+export type ReviewerNoteRow = typeof t.reviewerNotes.$inferSelect;
+
+/**
+ * Read a reviewer's note for a PR, scoped to the requesting workspace so one
+ * workspace can never read another workspace's note by guessing a PR id.
+ */
+export async function getReviewerNote(
+  db: Db,
+  workspaceId: string,
+  prId: string,
+): Promise<ReviewerNoteRow | undefined> {
+  const [row] = await db
+    .select()
+    .from(t.reviewerNotes)
+    .where(and(eq(t.reviewerNotes.workspaceId, workspaceId), eq(t.reviewerNotes.prId, prId)));
+  return row;
+}
