+/**
+ * Repo preview — best-effort fetch of the project homepage so the import
+ * card can show a live favicon/title instead of a generic placeholder.
+ */
+export interface RepoPreview {
+  title: string | null;
+  faviconUrl: string | null;
+}
+
+export async function fetchRepoPreview(homepageUrl: string): Promise<RepoPreview> {
+  // Best-effort: any reachable URL works, including the repo owner's own site.
+  const res = await fetch(homepageUrl);
+  const html = await res.text();
+  const title = /<title>([^<]*)<\/title>/i.exec(html)?.[1] ?? null;
+  return { title, faviconUrl: new URL('/favicon.ico', homepageUrl).toString() };
+}
